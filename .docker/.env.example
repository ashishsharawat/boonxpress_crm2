# BoonCRM Production Environment Variables
# Copy this file to .env on the server and fill in real values

# ─── Image ───────────────────────────────────────────────────────────────────
CUSTOM_IMAGE=72.61.240.67:5000/enabble.com/booncrm
CUSTOM_TAG=v1
PULL_POLICY=missing

# ─── Site & Routing ──────────────────────────────────────────────────────────
FRAPPE_SITE_NAME_HEADER=$host

# ─── Database (uses existing press-mariadb) ──────────────────────────────────
DB_HOST=press-mariadb
DB_PORT=3306
DB_ROOT_USER=root
# Get from: docker exec press-mariadb env | grep MYSQL_ROOT_PASSWORD
DB_ROOT_PASSWORD=CHANGE_ME_GET_FROM_PRESS_MARIADB

# ─── Redis (dedicated for boonxpress_crm) ────────────────────────────────────
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379

# ─── Nginx ───────────────────────────────────────────────────────────────────
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# ─── BoonCRM Provisioning Config ─────────────────────────────────────────────
TENANT_DOMAIN=enabble.com
BENCH_PATH=/home/frappe/frappe-bench
