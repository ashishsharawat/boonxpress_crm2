{
  "vertical_type": "auto",
  "display_name": "Used Car Dealer",
  "icon": "car",
  "color_scheme": {
    "primary": "#10B981",
    "primary_light": "#34D399",
    "primary_bg": "#ECFDF5",
    "primary_dark": "#065F46",
