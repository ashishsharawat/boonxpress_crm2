    { "fieldname": "vehicle_interest", "label": "Looking For", "fieldtype": "Data" },
    { "fieldname": "budget_range", "label": "Budget Range", "fieldtype": "Select", "options": "Under 3L\n3-5L\n5-8L\n8-12L\n12-20L\nAbove 20L" },
    { "fieldname": "fuel_preference", "label": "Fuel Preference", "fieldtype": "Select", "options": "Petrol\nDiesel\nCNG\nElectric\nHybrid\nNo Preference" }
  ],
  "lead_fields": [
    { "fieldname": "vehicle_segment", "label": "Segment", "fieldtype": "Select", "options": "Hatchback\nSedan\nSUV\nMUV\nLuxury" },
    { "fieldname": "heat_score", "label": "Heat Score", "fieldtype": "Select", "options": "Hot\nWarm\nCold" }
  ],
  "stats_config": [
    { "key": "test_drives_today", "label": "Test Drives", "icon": "Car" },
    { "key": "hot_leads", "label": "Hot Leads", "icon": "Flame" },
    { "key": "wa_pending", "label": "WA Pending", "icon": "MessageCircle" }
  ],
  "terminology": {
    "contact": "Customer",
    "lead": "Lead",
    "deal": "Test Drive",
    "organization": null
  },
  "fab_actions": [
    { "label": "New Lead", "icon": "UserPlus", "action": "create_lead" },
    { "label": "Log Walk-in", "icon": "FootprintsIcon", "action": "create_walkin" }
  ],
  "conversion_mode": "manual",
  "leads_segments": [
    { "key": "new", "label": "New", "filter": { "doctype": "CRM Lead", "status_in": ["Open", "Replied"] } },
    { "key": "pipeline", "label": "Pipeline", "filter": { "doctype": "CRM Deal", "status_not_in": ["Won", "Lost"] } },
    { "key": "closed", "label": "Closed", "filter": { "doctype": "*", "status_in": ["Lost"] } }
  ],
  "clients_segments": [
    { "key": "all", "label": "All", "filter": null },
    { "key": "service", "label": "Service customers", "filter": { "has_service_tag": true } },
    { "key": "lapsed", "label": "Lapsed", "filter": { "days_since_last_visit_gt": 180 } }
  ],
  "deal_stages": ["Qualification", "Inspection", "Quote", "Negotiation"],
  "person_primary_action": { "label": "Send Quote", "icon": "FileText", "action": "create_deal" },
  "profile_fields": [
    { "key": "vehicle_make", "label": "Vehicle make", "type": "text" },
    { "key": "vehicle_model", "label": "Vehicle model", "type": "text" },
    { "key": "registration_no", "label": "Registration no.", "type": "text" }
  ],
  "activity_event_types": ["whatsapp", "call", "stage", "note", "appointment"],
  "appointment_to_deal_status_map": {}
}
